{
  "expo": {
    "name": "Klyk",
    "slug": "cofounder-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": { "resizeMode": "contain", "backgroundColor": "#F4F2EE" },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Klyk to access your photos so you can set a profile picture."
        }
      ]
    ],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.cofounder.app" },
    "android": { "package": "com.cofounder.app" },
    "web": { "bundler": "metro" }
  }
}